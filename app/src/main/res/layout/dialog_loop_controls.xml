<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1E1E2E"
    android:paddingHorizontal="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="12dp">

    <!-- 顶部极窄横杠 -->
    <View
        android:layout_width="30dp"
        android:layout_height="3dp"
        android:layout_gravity="center_horizontal"
        android:background="#444466"
        android:layout_marginBottom="8dp"/>

    <!-- 极简播放器控制区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#2E2E3E"
        android:padding="8dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">
            <ImageButton android:id="@+id/btn_dialog_prev" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_media_previous" app:tint="#FFFFFF" android:scaleType="fitCenter"/>
            <ImageButton android:id="@+id/btn_dialog_play_pause" android:layout_width="44dp" android:layout_height="44dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_media_play" android:scaleType="fitCenter" android:padding="4dp" app:tint="#BB86FC"/>
            <ImageButton android:id="@+id/btn_dialog_next" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_media_next" app:tint="#FFFFFF" android:scaleType="fitCenter"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView android:id="@+id/tv_dialog_current_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00:00" android:textColor="#BBBBCC" android:textSize="10sp"/>
            <SeekBar android:id="@+id/sb_dialog_progress" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:progressTint="#BB86FC" android:thumbTint="#BB86FC" android:paddingVertical="4dp" android:maxHeight="3dp"/>
            <TextView android:id="@+id/tv_dialog_total_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00:00" android:textColor="#BBBBCC" android:textSize="10sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 紧凑微调主体 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 循环起点 (A) 紧凑版 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#252535"
            android:padding="8dp"
            android:layout_marginBottom="6dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="循环起点 (A)"
                    android:textColor="#8FBBD9"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/et_loop_start_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20.647"
                    android:textColor="#E0E0E0"
                    android:textSize="12sp"
                    android:background="@null"
                    android:gravity="end"
                    android:inputType="numberDecimal"
                    android:imeOptions="actionDone"/>
            </LinearLayout>

            <EditText
                android:id="@+id/et_loop_start_samples"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="991043"
                android:textColor="#A0C3FF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginVertical="2dp"
                android:background="@null"
                android:inputType="number"
                android:imeOptions="actionDone"/>

            <!-- 按钮组 A -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="2dp">
                <Button android:id="@+id/btn_a_min" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:text="最小" android:textSize="10sp" android:backgroundTint="#353545" android:layout_marginEnd="2dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_a_set_current" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:text="当前" android:textSize="10sp" android:backgroundTint="#554477" android:layout_marginEnd="2dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_a_max" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:text="最大" android:textSize="10sp" android:backgroundTint="#353545" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="2dp">
                <Button android:id="@+id/btn_a_dec_5s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="-5s" android:textSize="9sp" android:backgroundTint="#353545" android:layout_marginEnd="1dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_a_dec_1s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="-1s" android:textSize="9sp" android:backgroundTint="#353545" android:layout_marginEnd="1dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_a_inc_1s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="+1s" android:textSize="9sp" android:backgroundTint="#353545" android:layout_marginEnd="1dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_a_inc_5s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="+5s" android:textSize="9sp" android:backgroundTint="#353545" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn_a_dec_01s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="-0.1s" android:textSize="9sp" android:backgroundTint="#353545" android:layout_marginEnd="1dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_a_dec_001s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="-0.01s" android:textSize="9sp" android:backgroundTint="#353545" android:layout_marginEnd="1dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_a_inc_001s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="+0.01s" android:textSize="9sp" android:backgroundTint="#353545" android:layout_marginEnd="1dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_a_inc_01s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="+0.1s" android:textSize="9sp" android:backgroundTint="#353545" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 循环终点 (B) 紧凑版 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#252535"
            android:padding="8dp"
            android:layout_marginBottom="8dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="循环终点 (B)"
                    android:textColor="#F398AF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/et_loop_end_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="84.651"
                    android:textColor="#E0E0E0"
                    android:textSize="12sp"
                    android:background="@null"
                    android:gravity="end"
                    android:inputType="numberDecimal"
                    android:imeOptions="actionDone"/>
            </LinearLayout>

            <EditText
                android:id="@+id/et_loop_end_samples"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4063248"
                android:textColor="#FFB0C0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginVertical="2dp"
                android:background="@null"
                android:inputType="number"
                android:imeOptions="actionDone"/>

            <!-- 按钮组 B -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="2dp">
                <Button android:id="@+id/btn_b_min" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:text="最小" android:textSize="10sp" android:backgroundTint="#353545" android:layout_marginEnd="2dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_b_set_current" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:text="当前" android:textSize="10sp" android:backgroundTint="#554477" android:layout_marginEnd="2dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_b_max" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:text="最大" android:textSize="10sp" android:backgroundTint="#353545" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="2dp">
                <Button android:id="@+id/btn_b_dec_5s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="-5s" android:textSize="9sp" android:backgroundTint="#353545" android:layout_marginEnd="1dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_b_dec_1s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="-1s" android:textSize="9sp" android:backgroundTint="#353545" android:layout_marginEnd="1dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_b_inc_1s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="+1s" android:textSize="9sp" android:backgroundTint="#353545" android:layout_marginEnd="1dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_b_inc_5s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="+5s" android:textSize="9sp" android:backgroundTint="#353545" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/btn_b_dec_01s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="-0.1s" android:textSize="9sp" android:backgroundTint="#353545" android:layout_marginEnd="1dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_b_dec_001s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="-0.01s" android:textSize="9sp" android:backgroundTint="#353545" android:layout_marginEnd="1dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_b_inc_001s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="+0.01s" android:textSize="9sp" android:backgroundTint="#353545" android:layout_marginEnd="1dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
                <Button android:id="@+id/btn_b_inc_01s" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:text="+0.1s" android:textSize="9sp" android:backgroundTint="#353545" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:padding="0dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_audition"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="试听 (B-3s)"
            android:textSize="12sp"
            android:backgroundTint="#BB86FC"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btn_close_dialog"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="完成微调"
            android:textSize="12sp"
            android:backgroundTint="#444466"
            android:textColor="#FFFFFF"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:padding="0dp"/>

    </LinearLayout>

</LinearLayout>
