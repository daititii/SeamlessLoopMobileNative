<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1E1E2E"
    android:padding="16dp">

    <!-- 顶部横杠，提示可以下拉 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#444466"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loop &amp; Playback Control"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- 播放器控制区（从主界面上升而来的感觉） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#2E2E3E"
        android:padding="12dp"
        android:elevation="4dp"
        android:layout_marginBottom="16dp">

        <!-- 播放/暂停控制 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btn_dialog_prev"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#FFFFFF"/>
            <ImageButton
                android:id="@+id/btn_dialog_play_pause"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_play"
                android:scaleType="fitCenter"
                android:padding="8dp"
                app:tint="#BB86FC"/>
            <ImageButton
                android:id="@+id/btn_dialog_next"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_next"
                app:tint="#FFFFFF"/>
        </LinearLayout>

        <!-- 进度条 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <TextView
                android:id="@+id/tv_dialog_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#BBBBCC"
                android:textSize="12sp"/>
            <SeekBar
                android:id="@+id/sb_dialog_progress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="#BB86FC"
                android:thumbTint="#BB86FC"/>
            <TextView
                android:id="@+id/tv_dialog_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#BBBBCC"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 循环点微调区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- A 点 (Start) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#252535"
            android:padding="10dp"
            android:layout_marginBottom="12dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Loop Start (A)"
                    android:textColor="#E0E0E0"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_loop_start_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00.000"
                    android:textColor="#BB86FC"
                    android:textStyle="bold"/>
            </LinearLayout>
            <TextView
                android:id="@+id/tv_loop_start_samples"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Samples: 0"
                android:textColor="#BB86FC"
                android:textSize="12sp"
                android:gravity="end"
                android:padding="4dp"
                android:background="#1AFFFFFF"
                android:layout_marginBottom="8dp"
                android:drawableEnd="@android:drawable/ic_menu_edit"
                android:drawableTint="#8888AA"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">
                <Button android:id="@+id/btn_dec_start_50ms" android:layout_width="wrap_content" android:layout_height="36dp" android:text="-50ms" android:textSize="10sp" android:layout_marginEnd="4dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="#E0E0E0"/>
                <Button android:id="@+id/btn_dec_start_10ms" android:layout_width="wrap_content" android:layout_height="36dp" android:text="-10ms" android:textSize="10sp" android:layout_marginEnd="4dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="#E0E0E0"/>
                <Button android:id="@+id/btn_set_start_current" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="SET CURRENT" android:textSize="10sp" android:backgroundTint="#BB86FC" android:textColor="#000000" />
                <Button android:id="@+id/btn_inc_start_10ms" android:layout_width="wrap_content" android:layout_height="36dp" android:text="+10ms" android:textSize="10sp" android:layout_marginStart="4dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="#E0E0E0"/>
                <Button android:id="@+id/btn_inc_start_50ms" android:layout_width="wrap_content" android:layout_height="36dp" android:text="+50ms" android:textSize="10sp" android:layout_marginStart="4dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="#E0E0E0"/>
            </LinearLayout>
        </LinearLayout>

        <!-- B 点 (End) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#252535"
            android:padding="10dp"
            android:layout_marginBottom="12dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Loop End (B)"
                    android:textColor="#E0E0E0"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_loop_end_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00.000"
                    android:textColor="#BB86FC"
                    android:textStyle="bold"/>
            </LinearLayout>
            <TextView
                android:id="@+id/tv_loop_end_samples"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Samples: 0"
                android:textColor="#BB86FC"
                android:textSize="12sp"
                android:gravity="end"
                android:padding="4dp"
                android:background="#1AFFFFFF"
                android:layout_marginBottom="8dp"
                android:drawableEnd="@android:drawable/ic_menu_edit"
                android:drawableTint="#8888AA"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">
                <Button android:id="@+id/btn_dec_end_50ms" android:layout_width="wrap_content" android:layout_height="36dp" android:text="-50ms" android:textSize="10sp" android:layout_marginEnd="4dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="#E0E0E0"/>
                <Button android:id="@+id/btn_dec_end_10ms" android:layout_width="wrap_content" android:layout_height="36dp" android:text="-10ms" android:textSize="10sp" android:layout_marginEnd="4dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="#E0E0E0"/>
                <Button android:id="@+id/btn_set_end_current" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="SET CURRENT" android:textSize="10sp" android:backgroundTint="#BB86FC" android:textColor="#000000" />
                <Button android:id="@+id/btn_inc_end_10ms" android:layout_width="wrap_content" android:layout_height="36dp" android:text="+10ms" android:textSize="10sp" android:layout_marginStart="4dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="#E0E0E0"/>
                <Button android:id="@+id/btn_inc_end_50ms" android:layout_width="wrap_content" android:layout_height="36dp" android:text="+50ms" android:textSize="10sp" android:layout_marginStart="4dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="#E0E0E0"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    
    <Button
        android:id="@+id/btn_close_dialog"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="DONE"
        android:backgroundTint="#444466"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp"/>

</LinearLayout>
